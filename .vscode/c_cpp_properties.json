{
  "configurations": [
    {
      "name": "macOS arm64",
      "includePath": [
        "${workspaceFolder}/include",
        "${workspaceFolder}/vendor",
        "/opt/homebrew/include",
        "/opt/homebrew/opt/sqlite/include",
        "/opt/homebrew/opt/openssl@3/include",
        "/usr/include"
      ],
      "defines": [],
      "macFrameworkPath": ["/System/Library/Frameworks"],
      "compilerPath": "/usr/bin/clang",
